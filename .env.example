# OpenWeatherMap — crie uma conta em https://openweathermap.org/api
# Copie este arquivo para .env e preencha a chave.
# IMPORTANTE: reinicie o Metro (npm start) depois de criar ou alterar o .env.
EXPO_PUBLIC_OWM_API_KEY=sua_chave_aqui

# API local do Arduino.
# No celular físico, use o IP da máquina que roda o servidor (ex.: http://192.168.1.15:3000).
EXPO_PUBLIC_ARDUINO_API_URL=http://localhost:3000
