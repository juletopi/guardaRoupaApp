# Copie este arquivo para .env e preencha a chave.
# IMPORTANTE: reinicie o Metro (npm start) depois de criar ou alterar o .env.

# OpenWeatherMap — crie uma conta em https://openweathermap.org/api e gere uma 
# chave de API gratuita para acessar os dados meteorológicos. Insira a chave abaixo.
EXPO_PUBLIC_OWM_API_KEY=sua_chave_aqui

# API local do Arduino - No celular físico, use o IP da máquina que roda o servidor
# (ex.: http://192.168.1.15:3000). No emulador, localhost funciona normalmente.
EXPO_PUBLIC_ARDUINO_API_URL=http://SEU_IP_DA_MAQUINA:3000
